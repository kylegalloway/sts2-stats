{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Vite",
      "type": "npm",
      "script": "dev",
      "path": "packages/client/",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      }
    },
    {
      "label": "Dev (server + client)",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Bootstrap",
      "type": "npm",
      "script": "bootstrap",
      "problemMatcher": []
    },
    {
      "label": "Build",
      "type": "npm",
      "script": "build",
      "problemMatcher": "$tsc"
    }
  ]
}
